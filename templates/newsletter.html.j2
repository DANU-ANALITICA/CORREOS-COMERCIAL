{% from "partials/_macros.html.j2" import social_icons, logo_social_row, divider_line, discovery_banner, legal_footer with context %}
<!DOCTYPE html>
<html lang="es" xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="x-apple-disable-message-reformatting">
  <title>{{ subject }}</title>
  <!--[if mso]>
  <noscript>
    <xml>
      <o:OfficeDocumentSettings>
        <o:PixelsPerInch>96</o:PixelsPerInch>
      </o:OfficeDocumentSettings>
    </xml>
  </noscript>
  <![endif]-->
  <style>
    @media screen and (max-width: 620px) {
      .wrapper { width: 100% !important; }
      .stack { display: block !important; width: 100% !important; max-width: 100% !important; }
      .footer-apps { text-align: left !important; padding-top: 16px !important; }
      .header-share { text-align: left !important; padding-top: 12px !important; }
    }
  </style>
</head>
<body style="margin:0;padding:0;background-color:#f4f4f4;-webkit-text-size-adjust:100%;-ms-text-size-adjust:100%;">

  <div style="display:none;font-size:1px;color:#f4f4f4;line-height:1px;max-height:0;max-width:0;opacity:0;overflow:hidden;">
    {{ preheader }}
  </div>

  <center style="width:100%;background-color:#f4f4f4;">
    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%" style="background-color:#f4f4f4;">
      <tr>
        <td align="center" style="padding:24px 12px;">
          <table role="presentation" class="wrapper" cellspacing="0" cellpadding="0" border="0" width="600" style="max-width:600px;width:100%;background-color:#ffffff;">

            <tr>
              <td style="padding:24px 32px 16px 32px;">
                {{ logo_social_row() }}
              </td>
            </tr>

            <tr>
              <td style="padding:0 32px;">
                {{ divider_line() }}
              </td>
            </tr>

            <tr>
              <td style="padding:28px 32px 8px 32px;">
                <p style="margin:0 0 20px 0;font-family:Arial,Helvetica,sans-serif;font-size:16px;line-height:24px;font-weight:700;color:#000000;">
                  {{ greeting }}
                </p>
                <p style="margin:0 0 24px 0;font-family:Arial,Helvetica,sans-serif;font-size:15px;line-height:24px;color:#333333;white-space:pre-line;">
                  {{ hero_body }}
                </p>
                <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin:0 0 24px 0;">
                  <tr>
                    <td align="left" style="background-color:{{ cta_color }};border-radius:4px;">
                      <a href="{{ cta_url }}" target="_blank" style="display:inline-block;padding:10px 22px;font-family:Arial,Helvetica,sans-serif;font-size:14px;font-weight:600;color:#ffffff;text-decoration:none;background-color:{{ cta_color }};border:1px solid {{ cta_color }};">
                        {{ cta_text }}
                      </a>
                    </td>
                  </tr>
                </table>
                <p style="margin:0 0 8px 0;font-family:Arial,Helvetica,sans-serif;font-size:12px;line-height:18px;color:#333333;">
                  {{ social_icons() }}
                </p>
                <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:13px;line-height:20px;">
                  <a href="{{ company_contact }}" target="_blank" style="color:{{ cta_color }};font-weight:600;text-decoration:none;">
                    ✉️ Establece contacto con nosotros
                  </a>
                </p>
              </td>
            </tr>

            <tr>
              <td style="padding:0;font-size:0;line-height:0;">
                {{ discovery_banner() }}
              </td>
            </tr>

            <tr>
              <td style="padding:0 32px;">
                {{ divider_line() }}
              </td>
            </tr>

            <tr>
              <td style="padding:24px 32px;">
                {{ logo_social_row() }}
              </td>
            </tr>

            {% if promo_text %}
            <tr>
              <td style="padding:0 32px 24px 32px;">
                <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:13px;line-height:20px;color:#333333;">
                  {{ promo_text }}
                </p>
              </td>
            </tr>
            {% endif %}

            <tr>
              <td style="padding:24px 32px;background-color:#f0f0f0;">
                {{ legal_footer() }}
              </td>
            </tr>

          </table>
        </td>
      </tr>
    </table>
  </center>

</body>
</html>
